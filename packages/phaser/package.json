{
  "name": "@ai-game-assets/phaser",
  "version": "0.1.0",
  "description": "Phaser integration and in-game designer for prompt-aware AI game assets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzachshabtay/ai-assets.git",
    "directory": "packages/phaser"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-game-assets/core": "0.1.0"
  },
  "peerDependencies": {
    "phaser": ">=4"
  }
}
