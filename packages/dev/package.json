{
  "name": "@ai-game-assets/dev",
  "version": "0.1.0",
  "description": "Development server and AI providers for prompt-aware AI game assets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzachshabtay/ai-assets.git",
    "directory": "packages/dev"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ai-game-assets-dev": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-game-assets/core": "0.1.0",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0"
  },
  "peerDependencies": {
    "openai": ">=5"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  }
}
