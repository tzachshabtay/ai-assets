{
  "name": "@ai-game-assets/demo-space-invaders",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate-assets-module": "node scripts/write-assets-module.mjs",
    "build": "npm run build:dev",
    "build:dev": "npm run generate-assets-module && esbuild src/main.ts --bundle --format=esm --sourcemap --outfile=public/game.js",
    "build:web": "node scripts/write-assets-module.mjs --active-only --targets=default,wide,mobilePortrait --output-dir=dist/web && esbuild src/main.production.ts --bundle --format=esm --minify --outfile=dist/web/game.js",
    "build:phone": "node scripts/write-assets-module.mjs --active-only --targets=mobilePortrait --output-dir=dist/phone && esbuild src/main.android.ts --bundle --format=esm --minify --outfile=dist/phone/game.js",
    "build:tablet": "node scripts/write-assets-module.mjs --active-only --targets=wide --output-dir=dist/tablet && esbuild src/main.tablet.ts --bundle --format=esm --minify --outfile=dist/tablet/game.js",
    "build:production": "npm run build:web",
    "build:android": "npm run build:phone",
    "android:add": "npm run build:phone && cap add android",
    "android:sync": "npm run build:phone && cap sync android",
    "android:build:debug": "npm run android:sync && cd android && JAVA_HOME=${JAVA_HOME:-/opt/homebrew/opt/openjdk@21} ANDROID_HOME=${ANDROID_HOME:-/opt/homebrew/share/android-commandlinetools} ./gradlew assembleDebug",
    "android:devices": "ANDROID_HOME=${ANDROID_HOME:-/opt/homebrew/share/android-commandlinetools} sh -c '\"$ANDROID_HOME/platform-tools/adb\" devices'",
    "android:install:debug": "npm run android:build:debug && ANDROID_HOME=${ANDROID_HOME:-/opt/homebrew/share/android-commandlinetools} sh -c '\"$ANDROID_HOME/platform-tools/adb\" install -r android/app/build/outputs/apk/debug/app-debug.apk'",
    "android:open": "cap open android",
    "android:run": "npm run android:sync && JAVA_HOME=${JAVA_HOME:-/opt/homebrew/opt/openjdk@21} ANDROID_HOME=${ANDROID_HOME:-/opt/homebrew/share/android-commandlinetools} cap run android",
    "dev": "node dev-server.mjs",
    "typecheck": "npm run generate-assets-module && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-game-assets/core": "file:../../packages/core",
    "@ai-game-assets/dev": "file:../../packages/dev",
    "@ai-game-assets/phaser": "file:../../packages/phaser",
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "phaser": ">=4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.8.0"
  }
}
